// 12. GAME & WEB3 TEST
// ==========================================
Nova.game.start ("Action_RPG")
Nova.game.physics.gravity (9.8)
Nova.game.render ("3D")

Nova.blockchain.node.start ()
Nova.blockchain.nft.mint ("MyArtwork")

